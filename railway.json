{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["java"],
      "variables": {
        "NIXPACKS_JDK_VERSION": "21"
      }
    }
  },
  "deploy": {
    "startCommand": "java -Dserver.port=$PORT -jar target/*.jar",
    "restartPolicyType": "ON_FAILURE"
  }
}